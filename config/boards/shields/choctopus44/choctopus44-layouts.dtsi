/*
 * ZMK Studio physical layout for the choctopus44.
 *
 * Key order matches default_transform in choctopus44.dtsi exactly:
 *   row0: L c0-5, R c0-5
 *   row1: L c0-5, R c0-5
 *   row2: L c0-5, CENTER RC(3,0), R c0-5
 *   thumbs: L RC(3,2..5), R RC(7,0..3)
 * Coordinates are in 1/100 key units (approximate column-staggered geometry).
 */

#include <physical_layouts.dtsi>

/ {
    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Choctopus44";

        keys  //                     w   h    x    y   rot  rx  ry
            = <&key_physical_attrs 100 100    0   55    0   0   0>
            , <&key_physical_attrs 100 100  100   42    0   0   0>
            , <&key_physical_attrs 100 100  200   16    0   0   0>
            , <&key_physical_attrs 100 100  300    0    0   0   0>
            , <&key_physical_attrs 100 100  400   16    0   0   0>
            , <&key_physical_attrs 100 100  500   33    0   0   0>
            , <&key_physical_attrs 100 100  900   33    0   0   0>
            , <&key_physical_attrs 100 100 1000   16    0   0   0>
            , <&key_physical_attrs 100 100 1100    0    0   0   0>
            , <&key_physical_attrs 100 100 1200   16    0   0   0>
            , <&key_physical_attrs 100 100 1300   42    0   0   0>
            , <&key_physical_attrs 100 100 1400   55    0   0   0>
            , <&key_physical_attrs 100 100    0  155    0   0   0>
            , <&key_physical_attrs 100 100  100  142    0   0   0>
            , <&key_physical_attrs 100 100  200  116    0   0   0>
            , <&key_physical_attrs 100 100  300  100    0   0   0>
            , <&key_physical_attrs 100 100  400  116    0   0   0>
            , <&key_physical_attrs 100 100  500  133    0   0   0>
            , <&key_physical_attrs 100 100  900  133    0   0   0>
            , <&key_physical_attrs 100 100 1000  116    0   0   0>
            , <&key_physical_attrs 100 100 1100  100    0   0   0>
            , <&key_physical_attrs 100 100 1200  116    0   0   0>
            , <&key_physical_attrs 100 100 1300  142    0   0   0>
            , <&key_physical_attrs 100 100 1400  155    0   0   0>
            , <&key_physical_attrs 100 100    0  255    0   0   0>
            , <&key_physical_attrs 100 100  100  242    0   0   0>
            , <&key_physical_attrs 100 100  200  216    0   0   0>
            , <&key_physical_attrs 100 100  300  200    0   0   0>
            , <&key_physical_attrs 100 100  400  216    0   0   0>
            , <&key_physical_attrs 100 100  500  233    0   0   0>
            , <&key_physical_attrs 100 100  700  155    0   0   0>
            , <&key_physical_attrs 100 100  900  233    0   0   0>
            , <&key_physical_attrs 100 100 1000  216    0   0   0>
            , <&key_physical_attrs 100 100 1100  200    0   0   0>
            , <&key_physical_attrs 100 100 1200  216    0   0   0>
            , <&key_physical_attrs 100 100 1300  242    0   0   0>
            , <&key_physical_attrs 100 100 1400  255    0   0   0>
            , <&key_physical_attrs 100 100  250  370    0   0   0>
            , <&key_physical_attrs 100 100  350  390    0   0   0>
            , <&key_physical_attrs 100 100  450  400    0   0   0>
            , <&key_physical_attrs 100 100  550  400    0   0   0>
            , <&key_physical_attrs 100 100  850  400    0   0   0>
            , <&key_physical_attrs 100 100  950  400    0   0   0>
            , <&key_physical_attrs 100 100 1050  390    0   0   0>
            , <&key_physical_attrs 100 100 1150  370    0   0   0>
            ;
    };
};
